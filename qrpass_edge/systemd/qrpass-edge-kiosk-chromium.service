[Unit]
Description=QRPass Edge — Chromium в режиме киоска (локальный UI)
After=qrpass-edge.service
Requires=qrpass-edge.service

[Service]
Type=simple
User=qrpass
Group=qrpass
Environment=DISPLAY=:0
Environment=KIOSK_UNLOCK_FILE=/etc/qrpass/kiosk.unlock
ExecStart=/opt/qrpass_edge/scripts/run_kiosk.sh http://127.0.0.1:8088/
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
