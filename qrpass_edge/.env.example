# Локальная БД очереди (отдельный файл от users.db клиента)
QUEUE_DB_PATH=/var/lib/qrpass/edge_queue.db

# Куда складываются файлы нарушений/событий до отправки
STORAGE_ROOT=/var/lib/qrpass/violations

# Макс. размер STORAGE_ROOT (ГБ). 0 = автоочистка выключена
STORAGE_MAX_GB=150

# Сервер (как у qrpass_client)
SERVER_URL=https://example.com
API_TOKEN=change_me_api_token
SITE_NAME=
# false = полностью локальный режим (без пересылки на сайт)
UPSTREAM_ENABLED=true
# false = не отправлять видеопоток (/api/stream_frame) на сайт, но отправлять heartbeat/violations
UPSTREAM_STREAM_ENABLED=true
# Имя systemd-сервиса детектора (для кнопок Старт/Стоп/Рестарт в UI)
CLIENT_SERVICE_NAME=qrpass-client.service
# Шаблон процесса для статуса "запущен вручную" (если не через systemd)
CLIENT_PROCESS_PATTERN=qrpass_client/main.py

# UI киоска (локально)
EDGE_UI_HOST=127.0.0.1
EDGE_UI_PORT=8088

# Интервал фоновой отправки очереди (сек)
AGENT_POLL_SECONDS=5

# Автосигнал "камера жива" в /api/heartbeat (сек). 0 = выключить.
HEARTBEAT_INTERVAL_SECONDS=10

# Как часто повторять одинаковую heartbeat-ошибку в лог (сек).
HEARTBEAT_ERROR_LOG_COOLDOWN_SECONDS=60

# Имя камеры по умолчанию для heartbeat/preview и локальных тестов.
DEFAULT_CAMERA_NAME=EDGE-CAM-1

# Через сколько секунд без heartbeat камера считается offline в локальном UI.
CAMERA_ONLINE_SECONDS=20
LOG_FILE_PATH=/var/lib/qrpass/edge.log
LOG_MAX_MB=20
LOG_BACKUPS=5
