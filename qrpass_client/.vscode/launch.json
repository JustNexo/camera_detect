{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Клиент: main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Клиент: gui.py (лаунчер)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/gui.py",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
