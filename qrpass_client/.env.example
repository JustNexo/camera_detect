# =============================================================================
# Базовый URL API (qrpass_web) — без слэша в конце.
# Если на сервере ROOT_PATH=/qrpass_web (сайт открывается как https://домен/qrpass_web/...),
# укажите:  SERVER_URL=https://домен/qrpass_web
# Иначе POST уйдёт на https://домен/api/... и получите 404 — на сайте не будет камер и нарушений.
# Локально: http://127.0.0.1:8000
# =============================================================================
SERVER_URL=https://ваш-домен.ru

# Тот же секрет, что CLIENT_API_TOKEN в .env на сервере (скопируйте с хостинга)
API_TOKEN=вставьте_токен_с_сервера

# -----------------------------------------------------------------------------
# Режим А — одна камера (проще для теста). MDB не используется.
# -----------------------------------------------------------------------------
USE_MDB_CAMERAS=false
CAMERA_NAME=Камера 1
# Название объекта на сервере (группировка в веб-интерфейсе). Пусто = «Без объекта».
SITE_NAME=
CAMERA_SOURCE=0

# -----------------------------------------------------------------------------
# Режим Б — несколько камер из users.db (как у вас в папке new2 рядом с mdb.py).
# Раскомментируйте три строки ниже и выключите режим А (или поставьте USE_MDB_CAMERAS=true).
# Пример пути Linux: /home/ВАШ_ЛОГИН/camera_detect/new2
# -----------------------------------------------------------------------------
# USE_MDB_CAMERAS=true
# MDB_PARENT_DIR=/home/ВАШ_ЛОГИН/camera_detect/new2
# Обфусцированный mdb из dist/ + PyArmor:
# MDB_MODULE_FILE=/home/ВАШ/NEW2/dist/mdb.py
# PYARMOR_RUNTIME_DIR=/home/ВАШ/NEW2

# RTSP: как на старом объекте (открыть → один кадр → закрыть) — меньше ошибок h264 в логе
# RTSP_USE_SNAPSHOT=true
# TCP вместо UDP: RTSP_TRANSPORT_TCP=true
# Прогрев после открытия постоянного потока (0 = отключить): RTSP_WARMUP_FRAMES=5
# Пересоздавать поток каждые N сек (0 = нет): RTSP_RECONNECT_SECONDS=60

# -----------------------------------------------------------------------------
# Обученная модель (папка old/): детекция классов одежды + политика Rules в users.db
# Скопируйте best.pt рядом с клиентом или укажите путь. Имена классов — как в model.names.
# -----------------------------------------------------------------------------
# USE_TRAINED_MODEL=true
# YOLO_MODEL_PATH=best.pt
# TRAINED_CONF_THRESHOLD=0.5
# POLICY_COLOR_IDS=2,6,7
# POLICY_CLASS_PERSON=Person
# POLICY_CLASS_UNIFORM=Red uniform
# POLICY_CLASS_BARREL=Barrel
# Только эти классы участвуют в правилах (остальные детекты COCO игнорируются):
# POLICY_TRACKED_CLASSES=Person,Red uniform,Barrel
# CAMERA_ID=1
# MDB_PARENT_DIR=/home/ВАШ_ЛОГИН/camera_detect/new2

# -----------------------------------------------------------------------------
# Альтернатива: сегментация + HSV по таблице Colors (не смешивать с USE_TRAINED_MODEL)
# -----------------------------------------------------------------------------
# USE_COLOR_VIOLATIONS=true
# YOLO_MODEL_PATH=yolov8n-seg.pt
# SEG_CONF_THRESHOLD=0.7
# Для одной камеры укажите id строки в таблице Cameras:
# CAMERA_ID=1
# SQLITE_DB_PATH=users.db

YOLO_MODEL_PATH=yolov8n.pt
VIOLATION_CLASSES=no-helmet,no-vest,without_helmet,without_vest
VIOLATION_COOLDOWN_SECONDS=20
STREAM_INTERVAL_SECONDS=0.5
HEARTBEAT_INTERVAL_SECONDS=5
# Не слать heartbeat по всем камерам одним залпом (сек между камерами в одном цикле).
# HEARTBEAT_STAGGER_SECONDS=0.35
# Пауза после каждого цикла «кадр→инференс→отправка», как sleep(2) в old/main.py. 0 = максимальная частота (риск таймаутов при многих камерах).
# CYCLE_PAUSE_SECONDS=2
# USE_MDB_CAMERAS=true: случайная задержка старта потока камеры, 0..N сек (разнос пиков).
# MDB_THREAD_START_JITTER_MAX=2
