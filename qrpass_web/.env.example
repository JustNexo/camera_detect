APP_NAME=QRPass
SECRET_KEY=change_me_very_secret
DATABASE_URL=sqlite:///./qrpass_web.db
CLIENT_API_TOKEN=change_me_api_token

# Продакшен (Sprinthost): false — без демо-нарушений и без фейковых статусов камер. Локально можно true.
SEED_DEMO_DATA=false

# Опционально: при старте удалять из camera_presence строки старше N дней (убирает «призраков» после смены камер). 0 = выкл.
# CAMERA_PRESENCE_PRUNE_DAYS=30

# Если сайт открывается как https://домен/qrpass_web/ — укажите /qrpass_web. Если корень домена — оставьте пустым.
ROOT_PATH=

# Временно true — показать текст ошибки на странице входа (потом false)
SHOW_LOGIN_ERRORS=false

# Необязательно: каталог, куда веб-процесс точно может писать логи (например /tmp или ~/logs на Sprinthost)
ERROR_LOG_DIR=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=change_me
SMTP_FROM=alerts@example.com
SMTP_USE_TLS=true
# Порт 465 (часто Yandex/Google): SSL сразу — поставьте SMTP_USE_SSL=true и SMTP_USE_TLS=false
SMTP_USE_SSL=false
ALERT_TO_EMAIL=security@example.com
